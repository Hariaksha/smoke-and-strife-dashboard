# Copy this file to secrets.env (gitignored - never commit real values) and
# fill in your own credentials, then `source secrets.env` before running any
# pipeline command in this shell session.
#
#   cp secrets.env.example secrets.env
#   $EDITOR secrets.env
#   source secrets.env
#   python -m pipeline.run_update

export ACLED_EMAIL=""
export ACLED_PASSWORD=""
export FIRMS_MAP_KEY=""

# Either the Earthmover pair (preferred, low-latency) or CDSAPI_KEY (free
# fallback) - see README.md for how to obtain each.
export ARRAYLAKE_TOKEN=""
export ARRAYLAKE_ORG=""
export CDSAPI_KEY=""
